{
  "permissions": {
    "allow": [
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:arxiv.org)",
      "Bash(curl:*)",
      "Bash(cargo run:*)",
      "Bash(./target/debug/zero-nine governance:*)",
      "Bash(./target/debug/zero-nine mcp:*)",
      "Bash(./target/debug/zero-nine github:*)",
      "Bash(./target/debug/zero-nine skill:*)",
      "Bash(./target/debug/zero-nine observe:*)",
      "Bash(./test-services.sh)",
      "Bash(git add:*)",
      "Bash(git commit -m 'docs: 更新 README 融合架构说明和使用手册:*)",
      "Bash(git push:*)",
      "Bash(git commit -m 'chore: 删除废弃的 demo_project_v3 目录:*)",
      "Bash(npx skills:*)",
      "Bash(cargo clippy:*)",
      "Bash(git commit:*)",
      "Bash(grep -v \"^--$\")",
      "Skill(update-config)",
      "Bash(bc)",
      "Bash(grep -c \"test$\")",
      "Bash(grep -rn \"--resume\\\\|resume.*brainstorm\" /Users/tangxingzhuang/Freedom/Zero_Nine/crates/ --include=\"*.rs\")",
      "Bash(git status *)",
      "Bash(grep -A2 \"writing \\\\`&PathBuf\\\\`\")",
      "Bash(cargo install *)",
      "Read(//private/tmp/zn-dryrun-test/**)",
      "Bash(zero-nine resume *)",
      "Bash(zero-nine distill *)",
      "Bash(GIT_HTTP_LOW_SPEED_LIMIT=1000 GIT_HTTP_LOW_SPEED_TIME=10 git push *)",
      "Bash(grep -v \"zn-exec\\\\|zn-loop\\\\|zn-spec\\\\|zn-host\\\\|zn-cli.*unused variable: \\\\`now\\\\`\")",
      "Bash(gh pr *)",
      "Bash(cargo check *)",
      "Bash(grep -n \"^}$\" /Users/tangxingzhuang/Freedom/Zero_Nine/crates/zn-evolve/src/distiller.rs)",
      "Bash(brew install *)",
      "Bash(gh *)",
      "WebFetch(domain:www.bilibili.com)",
      "WebFetch(domain:m.toutiao.com)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_response.filePath // .tool_input.file_path' | { read -r f; echo \"$f\" | grep -q '\\.rs$' && rustfmt \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Formatting Rust..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cargo test --all-targets 2>&1 | grep \"test result\" | tail -10",
            "timeout": 120,
            "statusMessage": "Running quick verification..."
          }
        ]
      }
    ]
  }
}
